{
  "title": "AI Coder",
  "description": "Configuration for the JupyterLab AI Coder extension.",
  "jupyter.lab.shortcuts": [
    {
      "command": "ai-coder:inline-edit",
      "keys": ["Accel K"],
      "selector": ".jp-Notebook .jp-CodeMirrorEditor"
    },
    {
      "command": "ai-coder:open-chat",
      "keys": ["Accel L"],
      "selector": "body"
    },
    {
      "command": "ai-coder:cancel",
      "keys": ["Accel Shift Backspace"],
      "selector": "body"
    }
  ],
  "properties": {
    "defaultModel": {
      "type": "string",
      "default": "claude-sonnet-4",
      "title": "Default model"
    },
    "ghostText": {
      "type": "object",
      "title": "Ghost text completion",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "maxTokens": { "type": "integer", "default": 80 },
        "debounceMs": { "type": "integer", "default": 250 }
      },
      "default": { "enabled": true, "maxTokens": 80, "debounceMs": 250 }
    },
    "autoFixOnError": {
      "type": "boolean",
      "default": true,
      "title": "Show \"Fix with AI\" affordance after a cell errors"
    }
  },
  "type": "object"
}
