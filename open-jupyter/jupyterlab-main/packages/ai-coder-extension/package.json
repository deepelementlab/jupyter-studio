{
  "name": "@jupyterlab/ai-coder-extension",
  "version": "4.6.0-alpha.5",
  "description": "JupyterLab - AI Coder extension (chat sidebar, inline edit, ghost text, cell footer, task panel).",
  "homepage": "https://github.com/jupyterlab/jupyterlab",
  "bugs": {
    "url": "https://github.com/jupyterlab/jupyterlab/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jupyterlab/jupyterlab.git"
  },
  "license": "BSD-3-Clause",
  "author": "Jupyter Studio AI",
  "sideEffects": [
    "style/**/*.css",
    "style/index.js"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "style": "style/index.css",
  "directories": {
    "lib": "lib/"
  },
  "files": [
    "lib/*.d.ts",
    "lib/*.js.map",
    "lib/*.js",
    "schema/*.json",
    "style/**/*.css",
    "style/index.js",
    "src/**/*.{ts,tsx}"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf lib && rimraf tsconfig.tsbuildinfo",
    "test": "tsc -b && node lib/widgets/streamReducer.spec.js",
    "watch": "tsc -b --watch"
  },
  "dependencies": {
    "@jupyterlab/ai-coder": "^4.6.0-alpha.5",
    "@jupyterlab/application": "^4.6.0-alpha.5",
    "@jupyterlab/apputils": "^4.7.0-alpha.5",
    "@jupyterlab/cells": "^4.6.0-alpha.5",
    "@jupyterlab/codeeditor": "^4.6.0-alpha.5",
    "@jupyterlab/codemirror": "^4.6.0-alpha.5",
    "@jupyterlab/completer": "^4.6.0-alpha.5",
    "@jupyterlab/coreutils": "^6.6.0-alpha.5",
    "@jupyterlab/notebook": "^4.6.0-alpha.5",
    "@jupyterlab/rendermime": "^4.6.0-alpha.5",
    "@jupyterlab/services": "^7.6.0-alpha.5",
    "@jupyterlab/translation": "^4.6.0-alpha.5",
    "@jupyterlab/ui-components": "^4.6.0-alpha.5",
    "@lumino/coreutils": "^2.2.2",
    "@lumino/disposable": "^2.1.5",
    "@lumino/signaling": "^2.1.5",
    "@lumino/widgets": "^2.7.5",
    "react": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.26",
    "rimraf": "~5.0.5",
    "typescript": "~5.9.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "jupyterlab": {
    "extension": true,
    "schemaDir": "schema"
  },
  "styleModule": "style/index.js"
}
